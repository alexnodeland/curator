# Curator compose secrets + knobs. Copy NEXT TO compose.yaml as `.env`
# (compose reads it automatically; .env is gitignored) and fill in real
# values. Secrets live here or in the host environment — never in
# curator.toml, never in the image.

# REQUIRED by the core profile: the MCP bearer token. Generate one:
#   openssl rand -hex 32
CURATOR_MCP_TOKEN=change-me

# Zotero profile only: your Zotero API key (read access is enough).
#CURATOR_ZOTERO_KEY=change-me

# Host path of your vault (default: ./vault, created empty on first up).
#CURATOR_VAULT=~/vault

# Host path of the config file to mount (default: the shipped example).
#CURATOR_CONFIG_FILE=./examples/compose/curator.toml

# Host port for the MCP surface (default 8377).
#CURATOR_MCP_PORT=8377

# Loop intervals, seconds (zotero default 3600, librarian default 86400).
#CURATOR_SYNC_INTERVAL=3600
#CURATOR_DIGEST_INTERVAL=86400

# Set to --auto to let digests through the auto-apply gate.
#CURATOR_DIGEST_ARGS=
